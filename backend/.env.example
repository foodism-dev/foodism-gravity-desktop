# Server 本地开发环境变量模板
# 复制为 .env.server 后，修改 DATABASE_URL 指向你的本地 PostgreSQL 实例。

DATABASE_URL=postgres://postgres:postgres@localhost:5432/proma
PROMA_SERVER_JWT_SECRET=replace-with-a-long-random-local-secret
PORT=8787

# REBUILD OpenAPI 配置
REBUILD_BASE_URL=https://example.rebuild.local/
REBUILD_APP_ID=replace-with-app-id
REBUILD_APP_SECRET=replace-with-app-secret
REBUILD_LOGIN_USER=replace-with-rebuild-user
REBUILD_LOGIN_PASSWORD=replace-with-rebuild-password
REBUILD_LOGIN_COOKIE_TTL_SECONDS=1800

# 可选：配置后 REBUILD 登录 Cookie 会写入 Redis，未配置时使用进程内内存缓存。
REDIS_URL=redis://localhost:6379
