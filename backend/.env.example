# Server 本地开发环境变量模板
# 复制为 .env.server 后，修改 DATABASE_URL 指向你的本地 PostgreSQL 实例。

DATABASE_URL=postgres://postgres:postgres@localhost:5432/proma
PROMA_SERVER_JWT_SECRET=replace-with-a-long-random-local-secret
PORT=8787

# Web SSO 回调地址；需要同步加入 SSO client redirect_uris 白名单。
GRAVITY_WEB_REDIRECT_URI=http://127.0.0.1:8787/sso/callback

# REBUILD OpenAPI 配置
REBUILD_BASE_URL=https://example.rebuild.local/
REBUILD_APP_ID=replace-with-app-id
REBUILD_APP_SECRET=replace-with-app-secret
REBUILD_LOGIN_USER=replace-with-rebuild-user
REBUILD_LOGIN_PASSWORD=replace-with-rebuild-password
REBUILD_LOGIN_COOKIE_TTL_SECONDS=1800

# Redis：REBUILD 登录缓存可复用，同时 Lin-Ke 草稿任务队列必需。
REDIS_URL=redis://localhost:6379

# Cloudflare R2：Skill 市场发布和 Rebuild 图片素材镜像会用到。不要提交真实密钥。
CLOUDFLARE_R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
CLOUDFLARE_R2_BUCKET=replace-with-r2-bucket
CLOUDFLARE_R2_PUBLIC_BASE_URL=https://cdn.example.com
CLOUDFLARE_R2_PREFIX=upload_file
CLOUDFLARE_R2_REGION=auto
REBUILD_ASSET_R2_PREFIX=rebuild-assets

# FastAPI 文案优化模型配置
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_BASE_URL=
OPTIMIZE_MODEL=gpt-4o-mini
OPTIMIZE_CONCURRENCY=5
OPTIMIZE_MAX_BATCH_SIZE=20
OPTIMIZE_RETRIES=3

# 林客上品配置
LIN_KE_BASE_URL=https://www.life-partner.cn
LIN_KE_TIMEOUT=60
RB_IMAGE_BASE_URL=
