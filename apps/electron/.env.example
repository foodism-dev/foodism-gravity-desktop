# Desktop 本地开发环境变量模板

FOODISM_DEV=false

# 可选：覆盖本地配置目录
# FOODISM_GRAVITY_CONFIG_DIR=/Users/your-name/.foodism-gravity-dev

# Web 工单台地址；只配置 origin 时会自动跳到 /tickets。
VITE_PROMA_WORK_ORDERS_URL=http://localhost:5174/tickets

# 默认中转站配置。不要提交真实密钥。
FOODISM_DEFAULT_RELAY_API_KEY=replace-with-your-relay-api-key
FOODISM_DEFAULT_MODEL_ID=claude-opus-4-6

# Rebuild/OpenAPI 配置。不要提交真实密钥。
REBUILD_BASE_URL=https://example.com/
REBUILD_APP_ID=replace-with-your-app-id
REBUILD_APP_SECRET=replace-with-your-app-secret
